VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server/local only. Never prefix this with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_EMAIL=admin@medin.local
ADMIN_PASSWORD=change-this-password
ADMIN_FULL_NAME=Admin Medin
ADMIN_ROLE=platform_admin
CLINIC_SLUG=clinica-central

# Server/backend only. Configure these in Vercel for the backend service.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Medin <no-reply@your-domain.com>
RESEND_REPLY_TO_EMAIL=

# Server/backend only. Mercado Pago Checkout Pro.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_ENV=sandbox

# Public URLs. Keep APP_PUBLIC_URL on the active app domain used by Mercado Pago.
APP_PUBLIC_URL=https://app.medin.com.ar
# Temporary fallback domain, only during transition:
# APP_PUBLIC_URL=https://clinic-saas-mvp.vercel.app
LANDING_PUBLIC_URL=https://medin.com.ar
